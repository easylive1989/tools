<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.paulwu.claw</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/paulwu/.local/bin/uv</string>
        <string>run</string>
        <string>--directory</string>
        <string>/Users/paulwu/Documents/Github/tools/claw</string>
        <string>python</string>
        <string>-m</string>
        <string>claw</string>
    </array>

    <key>EnvironmentVariables</key>
